{
  "source_url": "https://www.gutenberg.org/files/14837/14837-h/14837-h.htm",
  "download_count": 28,
  "images": [
    {
      "index": 1,
      "filename": "image_001.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom04.jpg",
      "alt_text": "Mrs. Tabitha Twitchit and Children"
    },
    {
      "index": 2,
      "filename": "image_002.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom05.jpg",
      "alt_text": "Duck"
    },
    {
      "index": 3,
      "filename": "image_003.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom08.jpg",
      "alt_text": "Three Kittens"
    },
    {
      "index": 4,
      "filename": "image_004.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom11.jpg",
      "alt_text": "Once upon a time there were three little kittens, and their names were Mittens, Tom Kitten, and Moppet."
    },
    {
      "index": 5,
      "filename": "image_005.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom12.jpg",
      "alt_text": "First she scrubbed their faces (this one is Moppet)."
    },
    {
      "index": 6,
      "filename": "image_006.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom15.jpg",
      "alt_text": "Then she brushed their fur, (this one is Mittens)."
    },
    {
      "index": 7,
      "filename": "image_007.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom16.jpg",
      "alt_text": "Then she combed their tails and whiskers (this is Tom Kitten)."
    },
    {
      "index": 8,
      "filename": "image_008.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom19.jpg",
      "alt_text": "She took all sorts of elegant uncomfortable clothes out of a chest of drawers, in order to dress up her son Thomas."
    },
    {
      "index": 9,
      "filename": "image_009.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom20.jpg",
      "alt_text": "Tom Kitten was very fat, and he had grown; several buttons burst off."
    },
    {
      "index": 10,
      "filename": "image_010.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom23.jpg",
      "alt_text": "Now keep your frocks clean, children!"
    },
    {
      "index": 11,
      "filename": "image_011.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom24.jpg",
      "alt_text": "Moppet and Mittens walked down the garden path unsteadily."
    },
    {
      "index": 12,
      "filename": "image_012.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom27.jpg",
      "alt_text": "They turned their pinafores back to front."
    },
    {
      "index": 13,
      "filename": "image_013.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom28.jpg",
      "alt_text": "His hat fell off, and the rest of his buttons burst."
    },
    {
      "index": 14,
      "filename": "image_014.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom31.jpg",
      "alt_text": "Moppet and Mittens tried to pull him together."
    },
    {
      "index": 15,
      "filename": "image_015.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom32.jpg",
      "alt_text": "While they were in difficulties, there was a pit pat paddle pat!"
    },
    {
      "index": 16,
      "filename": "image_016.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom35.jpg",
      "alt_text": "The Puddle-Ducks"
    },
    {
      "index": 17,
      "filename": "image_017.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom36.jpg",
      "alt_text": "Then the two duck-birds, Rebeccah and Jemima Puddle-Duck, picked up the hat and tucker and put them on."
    },
    {
      "index": 18,
      "filename": "image_018.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom39.jpg",
      "alt_text": ">Mittens laughed so that she fell off the wall."
    },
    {
      "index": 19,
      "filename": "image_019.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom40.jpg",
      "alt_text": "Mr. Drake Puddle-Duck advanced in a slow sideways manner, and picked up the various articles."
    },
    {
      "index": 20,
      "filename": "image_020.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom43.jpg",
      "alt_text": "They fitted him even worse than Tom Kitten."
    },
    {
      "index": 21,
      "filename": "image_021.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom44.jpg",
      "alt_text": "And he and Jemima and Rebeccah Puddle-Duck set off up the road."
    },
    {
      "index": 22,
      "filename": "image_022.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom47.jpg",
      "alt_text": "Then Tabitha Twitchit came down the garden and found her kittens on the wall with no clothes on."
    },
    {
      "index": 23,
      "filename": "image_023.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom48.jpg",
      "alt_text": "She pulled them off the wall, smacked them, and took them back to the house."
    },
    {
      "index": 24,
      "filename": "image_024.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom51.jpg",
      "alt_text": "She sent them upstairs; and I am sorry to say she told her friends that they were in bed with the measles; which was not true."
    },
    {
      "index": 25,
      "filename": "image_025.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom52.jpg",
      "alt_text": "Quite the contrary; they were not in bed: not in the least."
    },
    {
      "index": 26,
      "filename": "image_026.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom55.jpg",
      "alt_text": "Somehow there were very extraordinary noises over-head."
    },
    {
      "index": 27,
      "filename": "image_027.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom57.jpg",
      "alt_text": "The clothes all came off directly, because there were no buttons."
    },
    {
      "index": 28,
      "filename": "image_028.jpg",
      "original_url": "https://www.gutenberg.org/files/14837/14837-h/images/tom58.jpg",
      "alt_text": "And Mr. Drake Puddle-Duck, and Jemima and Rebeccah, have been looking for them ever since."
    }
  ]
}
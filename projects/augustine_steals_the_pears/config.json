    "pages": [
      {
        "page_number": 1,
        "latin_text": "Augustīnus erat puer laetus.",
        "english_text": "Augustine was a happy boy.",
        "image_prompt": "A sunny field with green grass under a blue sky. A young boy stands in the center, arms outstretched, smiling joyfully. Bright, flat colors with simple shapes, eye-level angle, warm and cheerful mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_01.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer"
        ],
        "location": null
      },
      {
        "page_number": 2,
        "latin_text": "Amābat currere et rīdēre cum amīcīs.",
        "english_text": "He loved to run and laugh with friends.",
        "image_prompt": "A grassy hill under a clear sky. Three boys chase each other, laughing, in a playful run. Centered composition, eye-level angle, vibrant colors, energetic and happy mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_02.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer",
          "Amīcī"
        ],
        "location": null
      },
      {
        "page_number": 3,
        "latin_text": "Ūnā nocte, lūna clāra fulsit.",
        "english_text": "One night, the moon shone brightly.",
        "image_prompt": "A night sky with a glowing full moon casting soft light. Stars twinkle faintly. Centered on the moon, slightly above eye-level, cool blue tones, calm and serene mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_03.png",
        "vocabulary_used": [],
        "characters": [],
        "location": null
      },
      {
        "page_number": 4,
        "latin_text": "Pirus stābat trans saepem.",
        "english_text": "A pear tree stood beyond the fence.",
        "image_prompt": "A wooden fence under moonlight, with a tall pear tree full of fruit on the other side. Green leaves and yellow pears glow softly. Centered on the tree, eye-level angle, quiet and inviting mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_04.png",
        "vocabulary_used": [],
        "characters": [],
        "location": null
      },
      {
        "page_number": 5,
        "latin_text": "Pira erant rotunda et lucida.",
        "english_text": "The pears were round and shiny.",
        "image_prompt": "Close-up of a pear tree branch with round, shiny yellow pears under moonlight. Stars visible in the background. Centered on the pears, eye-level angle, bright and tempting mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_05.png",
        "vocabulary_used": [],
        "characters": [],
        "location": null
      },
      {
        "page_number": 6,
        "latin_text": "\"Capiāmus pira!\" dixērunt amīcī.",
        "english_text": "\"Let’s take the pears!\" said the friends.",
        "image_prompt": "Three boys huddle near a fence under moonlight, pointing at a pear tree. Mischievous expressions, whispering gestures. Centered on the group, eye-level angle, secretive and excited mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_06.png",
        "vocabulary_used": [],
        "characters": [
          "Amīcī"
        ],
        "location": null
      },
      {
        "page_number": 7,
        "latin_text": "Conscientia Augustīnī susurrāvit, \"Nōlī fūrārī.\"",
        "english_text": "Augustine’s conscience whispered, \"Don’t steal.\"",
        "image_prompt": "A young boy stands alone under a starry sky, head tilted as if listening. A faint, glowing cricket silhouette hovers near his shoulder. Centered on the boy, eye-level angle, quiet and introspective mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_07.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer"
        ],
        "location": null
      },
      {
        "page_number": 8,
        "latin_text": "Sed nōn audīvit.",
        "english_text": "But he didn’t listen.",
        "image_prompt": "A young boy turns away from a glowing cricket silhouette, looking toward a pear tree. Moonlit background with stars. Centered on the boy, eye-level angle, conflicted and curious mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_08.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer"
        ],
        "location": null
      },
      {
        "page_number": 9,
        "latin_text": "Tacitē trans saepem iērunt.",
        "english_text": "Silently, they went over the fence.",
        "image_prompt": "Three boys climb over a wooden fence under moonlight, tiptoeing carefully. Pear tree visible in the background. Centered on the action, slightly above eye-level, sneaky and tense mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_09.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer",
          "Amīcī"
        ],
        "location": null
      },
      {
        "page_number": 10,
        "latin_text": "Arborem agitāvērunt. Pira cecidērunt!",
        "english_text": "They shook the tree. Pears fell!",
        "image_prompt": "A pear tree shakes under moonlight, yellow pears falling to the ground. Boys’ hands visible on the trunk. Centered on the tree, eye-level angle, dynamic and chaotic mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_10.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer",
          "Amīcī"
        ],
        "location": null
      },
      {
        "page_number": 11,
        "latin_text": "Frūctūs abstulērunt et fūgērunt,",
        "english_text": "They took the fruit and fled,",
        "image_prompt": "Three boys run from a pear tree, holding yellow pears, under a starry sky. Fence in the background. Centered on the running boys, eye-level angle, hurried and excited mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_11.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer",
          "Amīcī"
        ],
        "location": null
      },
      {
        "page_number": 12,
        "latin_text": "et rīdentēs sub stēllīs.",
        "english_text": "and laughing under the stars.",
        "image_prompt": "Three boys laugh joyfully, holding pears, running under a starry night sky. Moonlight casts soft glows. Centered on the group, eye-level angle, playful and carefree mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_12.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer",
          "Amīcī"
        ],
        "location": null
      },
      {
        "page_number": 13,
        "latin_text": "Sed pira nōn erant bona.",
        "english_text": "But the pears were not good.",
        "image_prompt": "A pile of yellow pears on the ground, some bitten and discarded. Starry sky in the background. Centered on the pears, eye-level angle, disappointing and dim mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_13.png",
        "vocabulary_used": [],
        "characters": [],
        "location": null
      },
      {
        "page_number": 14,
        "latin_text": "Pira porcīs iēcērunt.",
        "english_text": "They threw the pears to the pigs.",
        "image_prompt": "Three pigs eat yellow pears scattered on the ground near a fence. Moonlight illuminates the scene. Centered on the pigs, eye-level angle, content and simple mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_14.png",
        "vocabulary_used": [],
        "characters": [
          "Porcī"
        ],
        "location": null
      },
      {
        "page_number": 15,
        "latin_text": "Porcī erant laetī. Augustīnus nōn erat laetus.",
        "english_text": "The pigs were happy. Augustine was not.",
        "image_prompt": "Three pigs munch pears happily, while a young boy stands nearby, head down, frowning. Moonlit field, starry sky. Centered on the contrast, eye-level angle, sad and reflective mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_15.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer",
          "Porcī"
        ],
        "location": null
      },
      {
        "page_number": 16,
        "latin_text": "Conscientia eius gravis erat.",
        "english_text": "His conscience was heavy.",
        "image_prompt": "A young boy sits on the ground, head in hands, under a starry sky. A faint cricket silhouette glows near him. Centered on the boy, eye-level angle, heavy and somber mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_16.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer"
        ],
        "location": null
      },
      {
        "page_number": 17,
        "latin_text": "Domum iit et cubitum iit.",
        "english_text": "He went home and to bed.",
        "image_prompt": "A small house under moonlight, a boy walking toward it with a sad expression. Starry sky above. Centered on the boy and house, eye-level angle, quiet and lonely mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_17.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer"
        ],
        "location": null
      },
      {
        "page_number": 18,
        "latin_text": "Sed dormīre nōn poterat.",
        "english_text": "But he couldn’t sleep.",
        "image_prompt": "A boy lies in a simple bed, eyes open, staring at the ceiling. Moonlight streams through a window. Centered on the boy, eye-level angle, restless and troubled mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_18.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer"
        ],
        "location": null
      },
      {
        "page_number": 19,
        "latin_text": "Tacitē sēdit et ōrāvit: \"Domine meus, doleō fūrārī pira et nōn audīre vōcem interiōrem.\"",
        "english_text": "He sat quietly and prayed: \"My Lord, I’m sorry for stealing pears and not listening to my inner voice.\"",
        "image_prompt": "A man kneels in a simple room, hands clasped, head bowed in prayer. Soft golden light glows around him. Centered on the man, eye-level angle, solemn and hopeful mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_19.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer"
        ],
        "location": null
      },
      {
        "page_number": 20,
        "latin_text": "Augustīnus amōrem Deī in corde sēnsit. Deus eī iamprīdem remīserat.",
        "english_text": "Augustine felt God’s love in his heart. God had forgiven him long ago.",
        "image_prompt": "A man stands in a simple room, arms raised, smiling peacefully, bathed in warm golden light. A starry sky visible through a window. Centered on the man, eye-level angle, joyful and serene mood.",
        "image_path": "projects/augustine_steals_the_pears/images/page_20.png",
        "vocabulary_used": [],
        "characters": [
          "Augustīnus Puer"
        ],
        "location": null
      },
      {
        "page_number": 21,
        "latin_text": "Cum dīcimus, \"Mē paenitet, Deus,\" Deus dīcit, \"Remittō tibi!\"",
        "english_text": "When we say, \"I’m sorry, God,\" God says, \"I forgive you!\"",
